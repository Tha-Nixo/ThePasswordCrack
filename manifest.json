{
  "manifest_version": 3,
  "name": "Password Game Solver",
  "version": "0.27",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.nytimes.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://neal.fun/password-game/*"],
      "js": ["dist/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://neal.fun/password-game/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/service-worker.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
